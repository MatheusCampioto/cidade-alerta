{
  "expo": {
    "name": "CidadeAlerta",
    "slug": "cidade-alerta",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cidadealerta",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d2d6e"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cidadealerta.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.cidadealerta.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "server",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "O CidadeAlerta precisa de acesso à câmera para fotografar ocorrências urbanas."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "O CidadeAlerta usa sua localização para registrar onde a ocorrência aconteceu."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "O CidadeAlerta precisa de acesso à galeria para selecionar fotos de ocorrências."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}